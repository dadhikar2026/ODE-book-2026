<diagram dimensions="(300,300)" margins="5" xmlns="https://prefigure.org">

    <coordinates bbox="(-1,-5,7,2)">

        <label anchor="(.5,1.2)" alignment="c">
            Derivative
        </label>
        <label anchor="(3.6,1.2)" alignment="c">
            Integral
        </label>

        <line endpoints="[(-.5,1.5),(4.5,1.5)]"
            arrows="0" stroke="black" thickness="2" />
        <line endpoints="[(-.5,1),(4.5,1)]"
            arrows="0" stroke="black" thickness="1" />

        <label anchor="(0,0.5)" alignment="c">
            <m>4x^2</m>
        </label>
        <label anchor="(0,-.7)" alignment="c">
            <m>8x</m>
        </label>
        <label anchor="(0,-1.9)" alignment="c">
            <m>8</m>
        </label>
        <label anchor="(0,-3.1)" alignment="c">
            <m>0</m>
        </label>


        <label anchor="(4,0.5)" alignment="c">
            <m>e^{4x}</m>
        </label>
        <label anchor="(4,-.7)" alignment="c">
            <m>\frac{1}{4}e^{4x}</m>
        </label>
        <label anchor="(4,-1.9)" alignment="c">
            <m>\frac{1}{16}e^{4x}</m>
        </label>
        <label anchor="(4,-3.1)" alignment="c">
            <m>\frac{1}{64}e^{4x}</m>
        </label>

        <line endpoints="[(0,0.3),(0,-.5)]"
            arrows="1" thickness="1" dash="2" />
        <line endpoints="[(0,-.9),(0,-1.7)]"
            arrows="1" thickness="1" dash="2" />
        <line endpoints="[(0,-2.1),(0,-2.9)]"
            arrows="1" thickness="1" dash="2" />


        <line endpoints="[(4,0.3),(4,-0.5)]" arrows="1" thickness="1" dash="2" />
        <line endpoints="[(4,-0.9),(4,-1.7)]" arrows="1" thickness="1" dash="2" />
        <line endpoints="[(4,-2.1),(4,-2.9)]" arrows="1" thickness="1" dash="2" />


        <line endpoints="[(0.35,0.45),(3.6,-0.5)]"
            arrows="1" stroke="red" thickness="1" />
        <line endpoints="[(0.35,-0.75),(3.6,-1.7)]"
            arrows="1" stroke="orange" thickness="1" />
        <line endpoints="[(0.35,-1.95),(3.65,-2.9)]"
            arrows="1" stroke="blue" thickness="1" />


        <label anchor="(2,-0.7)" alignment="c">
            <m>+</m>
        </label>
        <label anchor="(2,-1.9)" alignment="c">
            <m>-</m>
        </label>
        <label anchor="(2,-3.1)" alignment="c">
            <m>+</m>
        </label>
</coordinates>
</diagram>