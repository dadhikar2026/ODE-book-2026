              width=13cm,
              height=5cm,
              samples=100,
              domain=0:10,
            ]
              % Plot the solution y(t) = sum_{n=0}^\infty (-1)^n U(t-n) (1 - e^{-(t-n)})
              \addplot[blue, thick, domain=0:10] { (1 - exp(-x)) - (1 - exp(-(x-1))) * (x >= 1) + 
                (1 - exp(-(x-2))) * (x >= 2) - (1 - exp(-(x-3))) * (x >= 3) 
                + (1 - exp(-(x-4))) * (x >= 4) - (1 - exp(-(x-5))) * (x >= 5)
                 + (1 - exp(-(x-6))) * (x >= 6) - (1 - exp(-(x-7))) * (x >= 7) 
                 + (1 - exp(-(x-8))) * (x >= 8) - (1 - exp(-(x-9))) * (x >= 9) 
                 + (1 - exp(-(x-10))) * (x >= 10)};
